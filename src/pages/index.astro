---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// [Persona: WebDev] Logic:
// 1. Fetch the homepage settings from our JSON "Data" collection
// This allows you to update the Hero text via Decap CMS on the go.
const homeSettings = await getEntry('homepage', 'index');

// Safety check: if the JSON file isn't created yet, we provide defaults
const { 
  heroTitle = "Hi, I'm Duke.", 
  heroSubtitle = "Data isn't mystical. Let's take ownership of it.", 
  ctaText = "Explore the Data", 
  featuredPostSlug 
} = homeSettings?.data || {};

// 2. Fetch the specific featured blog post using the slug from the JSON
let featuredPost;
if (featuredPostSlug) {
  featuredPost = await getEntry('blog', featuredPostSlug);
}

// Fallback: If no slug is set, just grab the most recent post
if (!featuredPost) {
  const allPosts = await getCollection('blog');
  featuredPost = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];
}
---

<BaseLayout title="Data With Duke | Home">
  <!-- Hero Section -->
  <section class="py-24 px-4 max-w-6xl mx-auto text-center">
    <h1 class="text-5xl md:text-7xl font-extrabold mb-6 bg-gradient-to-r from-blue-900 to-blue-700 bg-clip-text text-transparent">
      {heroTitle}
    </h1>
    <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto leading-relaxed">
      {heroSubtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/podcast" class="btn-primary">
        {ctaText}
      </a>
      <a href="/blog" class="px-6 py-2.5 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition-all border border-slate-200">
        Read the Blog
      </a>
    </div>
  </section>

  <!-- Featured Showcase Section -->
  {featuredPost && (
    <section class="py-20 bg-slate-100/50 border-y border-slate-200/60">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex justify-between items-end mb-10">
          <div>
            <h2 class="text-3xl font-bold text-slate-900">Featured Insight</h2>
            <p class="text-slate-500 mt-1">Hand-picked for you today</p>
          </div>
          <a href="/blog" class="text-blue-900 font-semibold hover:underline decoration-2 underline-offset-4">View all posts →</a>
        </div>

        <div class="card-duke grid md:grid-cols-2 gap-12 items-center">
          <div class="order-2 md:order-1">
            <span class="inline-block px-3 py-1 rounded-full bg-blue-100 text-blue-900 text-xs font-bold uppercase tracking-wider mb-4">
              Latest Story
            </span>
            <h3 class="text-3xl font-bold mb-4 text-slate-900 leading-tight">{featuredPost.data.title}</h3>
            <p class="text-lg text-slate-600 mb-8 leading-relaxed">{featuredPost.data.description}</p>
            <a href={`/blog/${featuredPost.slug}`} class="btn-gold inline-block">
              Keep Reading
            </a>
          </div>
          
          <div class="order-1 md:order-2">
            {featuredPost.data.heroImage ? (
              <img 
                src={featuredPost.data.heroImage} 
                alt={featuredPost.data.title} 
                class="rounded-3xl shadow-2xl object-cover h-80 w-full hover:scale-[1.02] transition-transform duration-500"
              />
            ) : (
              <div class="h-80 w-full bg-blue-900 rounded-3xl flex items-center justify-center text-white/20">
                <!-- Fallback icon or pattern -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )}
</BaseLayout>